{
  "name": "chrome-plugins",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm --workspaces run build",
    "build:translator": "npm -w @chrome-plugins/translator run build",
    "build:twitter": "npm -w @chrome-plugins/twitter-image-blocker run build",
    "build:unified": "npm -w @chrome-plugins/unified run build",
    "dev": "node scripts/dev.mjs unified",
    "dev:translator": "node scripts/dev.mjs translator",
    "dev:twitter": "node scripts/dev.mjs twitter-image-blocker",
    "dev:unified": "node scripts/dev.mjs unified",
    "lint": "npm --workspaces run lint"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.1.42",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "ws": "^8.20.1"
  }
}
